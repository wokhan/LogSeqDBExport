        },
        "~:user.property/Importance-wdp0OL0Z": {
            "Target": "importance"
        },
        "~:user.property/Reason-hLioBfoW": {
            "Target": "reason"
        },
        "~:block/tags": {
            "Target": "type",
            "UnmappedTarget": "tags",
            "ValueMappings": {
                "Person": "person",
                "Company": "company",
                "Journal": "journal",
                "Team": "team",
                "Technology": "technology"
            }
        },
        "~:block/updated-at": {
            "Scope": "page",
            "Format": "{0:yyyy-MM-ddTHH:mm:ss}",
            "Target": "updated"
        },
        "~:block/created-at": {
            "Scope": "page",
            "Format": "{0:yyyy-MM-ddTHH:mm:ss}",
            "Target": "created"
        },
        "~:logseq.property/status": {
            "Mode": "prepend",
            "ValueMappings": {
                "Todo": "[ ]",
                "Pending": "[/]",
                "Doing": "[/]",
                "Done": "[X]",
                "Canceled": "[-]",
                "In Review": "[?]",
                "Backlog": "[~]"
            }
        },
        "~:logseq.property/priority": {
            "Mode": "append",
            "ValueMappings": {
                "Low": "🔽",
                "Medium": "🔼",
                "High": "⏫",
                "Urgent": "🔺",
                "None": ""
            }
        },
        "~:logseq.property/scheduled": {
            "Mode": "append",
            "Format": "⏳ {0:yyyy-MM-dd}"
        },
        "~:logseq.property/deadline": {
            "Mode": "append",
            "Format": " 📅 {0:yyyy-MM-dd}"
        },
        // "~:logseq.property.repeat/recur-frequency": {
        //     "Mode": "append",
        //     "Format": "🔁 {0}"
        // },
        "~:logseq.property.repeat/recur-unit": {
            "Mode": "append",
            "Format": "🔁 every {0}"
        }
    },
    "DateMapping": [
        "(\\d{2})-(\\d{2})-(\\d{4})",
        "$3-$2-$1"
    ]
}